{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aca-spec.org/schema/0.1/system.schema.json",
  "title": "ACA System",
  "description": "An ACA system manifest S = (Obj, H, K). It lists membership only; H (hierarchical edges) and K (lateral edges) are DERIVED from the member charters and never declared here.",
  "type": "object",
  "required": ["aca_version", "kind", "id", "objects"],
  "additionalProperties": false,
  "properties": {
    "aca_version": { "const": "0.1" },
    "kind": { "const": "System" },
    "id": {
      "type": "string",
      "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$"
    },
    "description": { "type": "string" },
    "objects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["charter"],
        "additionalProperties": false,
        "properties": {
          "charter": {
            "type": "string",
            "description": "Path or URI to a kind: Charter document."
          }
        }
      }
    }
  }
}
